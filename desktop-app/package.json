{
  "name": "qr-dine-cloud-desktop",
  "version": "1.0.0",
  "description": "QR Dine Cloud Desktop Application for Hotel Admins",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "author": "Sarthak Mulik",
  "license": "ISC",
  "dependencies": {},
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.qrdinecloud.desktop",
    "productName": "QR Dine Cloud",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
